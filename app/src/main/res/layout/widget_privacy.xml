<?xml version="1.0" encoding="utf-8"?>
<!-- API 26–30 fallback layout: uses static colors from @color/widget_* resources.
     The -night resource qualifier in values-night/colors.xml handles dark mode
     without requiring a DayNight theme.
     API 31+ devices use layout-v31/widget_privacy.xml instead. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background layer: opacity is applied only to this view so text/icons stay crisp.
         Uses ImageView because RemoteViews only supports a limited set of view types. -->
    <ImageView
        android:id="@+id/widget_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background"
        android:contentDescription="@null"
        android:importantForAccessibility="no" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Shield icon at horizontal center; declared first so other views can anchor to it. -->
        <ImageView
            android:id="@+id/widget_divider"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_widget_shield"
            android:tint="@color/widget_divider"
            android:contentDescription="@null" />

        <!-- Zero-height anchor at the exact vertical center of the widget.
             Both text columns position relative to this point so the combined
             two-line block is geometrically centered, not just one row. -->
        <TextView
            android:id="@+id/widget_center_anchor"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_centerInParent="true"
            android:text="" />

        <!-- OS name: sits just below the center anchor (bottom row, left column).
             This is also the baseline reference for "Good" on the right. -->
        <TextView
            android:id="@+id/widget_os_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/widget_divider"
            android:layout_below="@id/widget_center_anchor"
            android:layout_marginStart="24dp"
            android:layout_marginTop="1dp"
            android:paddingEnd="12dp"
            android:text="GrapheneOS"
            android:textColor="@color/widget_secondary_text"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Device name: sits just above the center anchor (top row, left column). -->
        <TextView
            android:id="@+id/widget_device_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/widget_divider"
            android:layout_above="@id/widget_center_anchor"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="1dp"
            android:paddingEnd="12dp"
            android:text="Pixel 9"
            android:textColor="@color/widget_primary_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Rating: layout_alignBaseline gives the exact same text baseline as OS name.
             toEndOf + alignParentEnd spans the full right half so gravity=center works. -->
        <TextView
            android:id="@+id/widget_score_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/widget_divider"
            android:layout_alignParentEnd="true"
            android:layout_alignBaseline="@id/widget_os_name"
            android:gravity="center"
            android:text="Good"
            android:textColor="@color/widget_secondary_text"
            android:textSize="14sp"
            android:maxLines="1" />

        <!-- Score container: centers the score value in the right column (top row). -->
        <LinearLayout
            android:id="@+id/widget_score_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/widget_divider"
            android:layout_alignParentEnd="true"
            android:layout_above="@id/widget_score_rating"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Score value -->
            <TextView
                android:id="@+id/widget_score_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85"
                android:textColor="@color/widget_primary_text"
                android:textSize="28sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Score change increase indicator: XML color resolves via resource qualifiers
             so theme changes (light/dark) always show the correct color. -->
        <TextView
            android:id="@+id/widget_privacy_change_up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="↑5"
            android:textColor="@color/widget_privacy_increase"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Score change decrease indicator -->
        <TextView
            android:id="@+id/widget_privacy_change_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="↓5"
            android:textColor="@color/widget_privacy_decrease"
            android:textSize="12sp"
            android:visibility="gone" />

    </RelativeLayout>

</FrameLayout>
